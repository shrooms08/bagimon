# Bags.fm API
BAGS_API_KEY=

# Helius (Solana RPC + webhooks)
HELIUS_API_KEY=

# Anthropic (Claude Haiku for pet personality)
ANTHROPIC_API_KEY=

# Discord bot
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
# DISCORD_DEV_GUILD_ID=  # set for instant slash command updates during dev; leave empty for global registration

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Phase 3 mood loop (optional — defaults are 30 / 5)
# MOOD_LOOP_INTERVAL_MINUTES=30
# MOOD_LOOP_CONCURRENCY=5

# Phase 4 personality rate limits (optional — defaults are 3 / 20)
# AI_RATE_LIMIT_USER_PER_HOUR=3
# AI_RATE_LIMIT_BAGIMON_PER_HOUR=20

# Phase 5 — public Petdex base URL (used by bot /bagimon link and web OG metadata)
# PETDEX_BASE_URL=https://bagimon.vercel.app

# Phase 6 — how many days continuously 'dying' before permanent death.
# Fractional values allowed for demos (e.g. 0.02 ≈ 30 min).
# DEATH_DAYS_THRESHOLD=14
# Set ENABLE_EXPEDITE=true to register the dev-only /bagimon expedite command
# that backdates the dying streak so the next tick kills a Bagimon. Never
# enable in production.
# ENABLE_EXPEDITE=false
NEXT_PUBLIC_PETDEX_BASE_URL=https://bagimon.vercel.app
# NEXT_PUBLIC_DISCORD_INVITE_URL=
