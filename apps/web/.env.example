# apps/web reads from the repo-root .env first (via next.config.js); values
# in apps/web/.env.local override.  All keys here are server-only (read in
# RSC / API routes); no client bundle exposure.

# Supabase — anon key, read-only via RLS.  Same names as the bot uses, so
# the repo-root .env satisfies both.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Canonical Petdex URL — used for OG metadata and the Discord /bagimon link
# command.  Public (will appear in HTML), so prefixed NEXT_PUBLIC_.
NEXT_PUBLIC_PETDEX_BASE_URL=https://bagimon.vercel.app

# Discord OAuth invite URL surfaced on the homepage CTA. Leave blank for now.
NEXT_PUBLIC_DISCORD_INVITE_URL=
